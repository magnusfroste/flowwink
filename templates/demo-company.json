                  ]
                },
                {
                  "type": "heading",
                  "attrs": {
                    "level": 2
                  },
                  "content": [
                    {
                      "type": "text",
                      "text": "What is not real"
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "No emails leave the building. No card is ever charged. Anything FlowPilot would have sent shows up as simulated in /admin/communications, and outbound skills queue proposals in /admin/approvals instead of firing."
                    }
                  ]
                },
                {
                  "type": "heading",
                  "attrs": {
                    "level": 2
                  },
                  "content": [
                    {
                      "type": "text",
                      "text": "Tip"
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Break things on purpose. Place a sandbox order, reject an approval, edit a quote, ask FlowPilot something odd. Whatever you do to the operational data, the next reset gives you a clean slate."
                    }
                  ]
                }
              ]
